{
  "name": "version2",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-stock-overview": "cds watch --open stockoverview/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-movement-console": "cds watch --open movementconsole/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-warehousemanagement": "cds watch --open warehousemanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-stockanalysis": "cds watch --open stockanalysis/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-category": "cds watch --open category/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "server": {
      "index": true
    },
    "requires": {
        "GEO_API": {
        "kind": "rest",
        "credentials": {
          "destination": "GEO_API"
        }
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "operator": {
              "password": "pass",
              "roles": [
                "Operator"
              ]
            },
            "manager": {
              "password": "pass",
              "roles": [
                "WarehouseManager"
              ]
            },
            "admin": {
              "password": "pass",
              "roles": [
                "Administrator"
              ]
            },
            "guest": {
              "password": "pass",
              "roles": []
            }
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/stock-overview",
    "app/movement-console",
    "app/warehousemanagement",
    "app/stockanalysis",
    "app/stockanalysis",
    "app/stockanalysis",
    "app/category"
  ]
}
